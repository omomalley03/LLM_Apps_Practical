#!/bin/bash
#SBATCH -A MLMI-omo26-SL2-GPU
#SBATCH -J NLU_DECODE_GPT2
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:1
#SBATCH --time=1:20:00
#SBATCH --mail-type=FAIL
#! Uncomment this to prevent the job from being requeued (e.g. if
#! interrupted by node failure or system downtime):
##SBATCH --no-requeue
#SBATCH -p ampere
#! ############################################################

. /etc/profile.d/modules.sh                # Leave this line (enables the module command)
module purge                               # Removes all modules still loaded
module load rhel8/default-amp
module load cuda/11.1 intel/mkl/2017.4
export OMP_NUM_THREADS=1

module load slurm
module load anaconda/3.2019-10
eval "$(conda shell.bash hook)"
source /rds/project/rds-xyBFuSj0hm0/MLMI8.L2024/envs/README.MLMI8.SEQ2SEQDST.activate

EXPERIMENT_NAME=gpt2_nlu
RUN_NAME=gpt2_nlu_decode

mkdir -p slurm_logs

JOBID=$SLURM_JOB_ID
LOG=slurm_logs/"$RUN_NAME".log_$JOBID.txt
ERR=slurm_logs/"$RUN_NAME".err_$JOBID.txt

echo -e "JobID: $JOBID\n======" > $LOG
echo "Time: `date`" >> $LOG
echo "Running on master node: `hostname`" >> $LOG

# HINT: USE A FOR LOOP TO LOOP OVER THE DIFFERENT CHECKPOINTS AND DECODE THEM IN SERIES IN A SINGLE JOB / SESSION
# This file only logs a single checkpoint for the test set

CHECKPOINT=model.60000
mkdir -p hyps/test/$EXPERIMENT_NAME/$CHECKPOINT

# The above folder must absolutely be created before running the script below, otherwise it will crash
WANDB_NAME="$EXPERIMENT_NAME"_decode_test_"$CHECKPOINT"
SCRIPT_FILE=$BDIR/src/decode-dst.py
HYPS_DIR=hyps/test
TEST_DATA=$BDIR/data_preparation/data/multiwoz21/processed/test/version_1/data.json
CHECKPOINTS_FOLDER=checkpoints/$EXPERIMENT_NAME

python $SCRIPT_FILE decode=gpt2 decode.hyp_dir=$HYPS_DIR \
        decode.test_data=$TEST_DATA \
        decode.checkpoints_dir=$CHECKPOINTS_FOLDER decode.checkpoint=$CHECKPOINT \
        decode.experiment_name=$EXPERIMENT_NAME \
        wandb.group="NLU" wandb.name=$WANDB_NAME \
        wandb.tags=["NLU","decode","GPT2"] >> $LOG 2>> $ERR

echo "Time: `date`" >> $LOG